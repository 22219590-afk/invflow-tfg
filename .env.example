# ── ODOO CONFIG ────────────────────────────────
# URL de tu instancia (ej: https://edutfg.odoo.com)
ODOO_URL=https://your-odoo-url.com
ODOO_DB=your-db-name
ODOO_USER=your-email@example.com
ODOO_PASSWORD=your-odoo-password
ODOO_PORT=443

# ── DATABASE CONFIG ────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=inventory_db
# Esta URL la usa el backend para hablar con la DB
DATABASE_URL=postgresql://admin:admin@db/inventory_db

# ── SECURITY ───────────────────────────────────
# Clave aleatoria para firmar tus tokens
JWT_SECRET_KEY=invflow_secure_secret_2024
