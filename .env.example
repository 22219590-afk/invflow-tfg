# ══════════════════════════════════════════════════════
#  InvFlow — Plantilla de variables de entorno
#  Copia este archivo a .env y rellena los valores reales
#  NUNCA subas .env al repositorio
# ══════════════════════════════════════════════════════

# ── ENTORNO ────────────────────────────────────────────
# "production" o "development"
ENVIRONMENT=production

# ── ODOO CONFIG ────────────────────────────────────────
# URL de la instancia Odoo del cliente
ODOO_URL=https://cliente.odoo.com
ODOO_DB=nombre-base-de-datos-odoo
ODOO_USER=usuario@empresa.com
ODOO_PASSWORD=contraseña-odoo-aqui
ODOO_PORT=443

# ── BASE DE DATOS ──────────────────────────────────────
# Usa contraseñas fuertes en producción (mínimo 20 caracteres)
POSTGRES_USER=invflow
POSTGRES_PASSWORD=CAMBIA_ESTO_POR_CONTRASEÑA_FUERTE
POSTGRES_DB=invflow_db
DATABASE_URL=postgresql://invflow:CAMBIA_ESTO_POR_CONTRASEÑA_FUERTE@db/invflow_db

# ── SEGURIDAD ──────────────────────────────────────────
# Genera una clave aleatoria fuerte:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CAMBIA_ESTO_POR_CLAVE_ALEATORIA_DE_64_CARACTERES

# ── CORS ───────────────────────────────────────────────
# Dominios autorizados a llamar a la API (separados por coma)
# En producción, pon SOLO tu dominio real
CORS_ORIGINS=https://app.tudominio.com
